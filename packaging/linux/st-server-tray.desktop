[Desktop Entry]
Type=Application
Name=st Server Tray
Comment=Status tray icon + controls for the st-server system service
Exec=systemd-cat -t st-server-tray /opt/st-server/st-server --tray
Icon=st-server
Terminal=false
Categories=Network;RemoteAccess;
X-GNOME-Autostart-enabled=true
StartupNotify=false
NoDisplay=true
