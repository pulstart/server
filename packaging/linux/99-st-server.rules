# Install as /etc/udev/rules.d/99-st-server.rules (or /usr/lib/udev/rules.d/).
#
# The only device node that needs a custom rule is /dev/uinput — no distro
# default makes it group-writable, and we need that for virtual mouse /
# keyboard injection. DRM and evdev nodes are deliberately left to the
# distro defaults so logind's per-session uaccess ACL for the logged-in
# user isn't wiped by a conflicting MODE/GROUP= here.

KERNEL=="uinput", MODE="0660", GROUP="input", TAG+="uaccess"
